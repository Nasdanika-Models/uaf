        <details key="documentation" value="Contains the elements that contribute to the Strategic Proceses Viewpoint."/>
      </eAnnotations>
      <eClassifiers xsi:type="ecore:EClass" name="ActualEnduringTask" eSuperTypes="#//Metadata/Processes/CapableElement #//Parameters/ActualPropertySet">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="An actual undertaking recognized by an enterprise as being essential to achieving its goals - i.e. a strategic specification of what the enterprise does."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL">
          <details key="ActualEnduringTask.classifier" value="Value for the classifier metaproperty must be stereotyped by «EnduringTask» or its specializations."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="constraints" value="ActualEnduringTaskclassifier"/>
