        <eStructuralFeatures xsi:type="ecore:EReference" name="resourceArchitectureOfEnterprisePhase" eType="#//Resources/Taxonomy/ResourceArchitecture" upperBound="-1"/>
        <eStructuralFeatures xsi:type="ecore:EReference" name="operationalArchitectureOfEnterprisePhase" eType="#//Operational/Structure/OperationalArchitecture" upperBound="-1"/>
        <eStructuralFeatures xsi:type="ecore:EReference" name="vision" eType="#//Strategic/Taxonomy/EnterpriseVision" upperBound="-1"/>
        <eStructuralFeatures xsi:type="ecore:EReference" name="goal" eType="#//Strategic/Taxonomy/EnterpriseGoal" upperBound="-1"/>
        <eStructuralFeatures xsi:type="ecore:EReference" name="statementTask" eType="#//Strategic/Processes/ActualEnduringTask" upperBound="-1"/>
        <eStructuralFeatures xsi:type="ecore:EReference" name="concern" eType="#//SummaryandOverview/Concern" upperBound="-1"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="Capability" eSuperTypes="#//Parameters/PropertySet #//Strategic/States/Desirer sysml.ecore#//Blocks/Block">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="An enterprise's ability to Achieve a DesiredEffect realized through a combination of ways and means (e.g. CapabilityConfigurations) along with specified measures."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="baseMetaclass" value="Class"/>
        </eAnnotations>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="EnterpriseGoal" eSuperTypes="#//Parameters/PropertySet sysml.ecore#//Requirements/Requirement">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="A statement about a state or condition of the enterprise to be brought about or sustained through appropriate Means. An EnterpriseGoal amplifies an EnterpriseVision that is, it indicates what must be satisfied on a continuing basis to effectively attain the EnterpriseVision. http://www.omg.org/spec/BMM/1.3/"/>
        </eAnnotations>
        <eStructuralFeatures xsi:type="ecore:EAttribute" name="benefits" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString" upperBound="-1"/>
        <eStructuralFeatures xsi:type="ecore:EReference" name="enterprisePhase" eType="#//Strategic/Taxonomy/ActualEnterprisePhase" upperBound="-1"/>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="baseMetaclass" value="Class"/>
        </eAnnotations>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="EnterprisePhase" eSuperTypes="#//Parameters/PropertySet sysml.ecore#//Blocks/Block">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="A type of a current or future state of the enterprise."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="baseMetaclass" value="Class"/>
        </eAnnotations>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="EnterpriseVision" eSuperTypes="#//Parameters/PropertySet sysml.ecore#//Blocks/Block">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="A Vision describes the future state of the enterprise, without regard to how it is to be achieved. http://www.omg.org/spec/BMM/1.3/"/>
        </eAnnotations>
        <eStructuralFeatures xsi:type="ecore:EReference" name="statement" eType="#//Strategic/Taxonomy/VisionStatement" upperBound="-1"/>
        <eStructuralFeatures xsi:type="ecore:EReference" name="enterprisePhase" eType="#//Strategic/Taxonomy/ActualEnterprisePhase"/>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="baseMetaclass" value="Class"/>
        </eAnnotations>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="VisionStatement" eSuperTypes="#//Parameters/MeasurableElement">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="A type of comment that describes the future state of the enterprise, without regard to how it is to be achieved. http://www.omg.org/spec/BMM/1.3/"/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL">
          <details key="VisionStatement.ownedAttribute" value="Values for annotatedElement metaproperty must be stereotyped «EnterpriseVision» or its specializations."/>
