      <eClassifiers xsi:type="ecore:EEnum" name="RoleKind">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Enumeration of the possible kinds of roles that a ResourceRole may play in the context of a ResourcePerformer."/>
        </eAnnotations>
        <eLiterals name="Part" value="0" literal="Part"/>
        <eLiterals name="Component" value="1" literal="Component"/>
        <eLiterals name="UsedConfiguration" value="2" literal="UsedConfiguration"/>
        <eLiterals name="HumanResource" value="3" literal="HumanResource"/>
        <eLiterals name="Platform" value="4" literal="Platform"/>
        <eLiterals name="System" value="5" literal="System"/>
        <eLiterals name="SubOrganization" value="6" literal="SubOrganization"/>
        <eLiterals name="PostRole" value="7" literal="PostRole"/>
        <eLiterals name="ResponsibilityRole" value="8" literal="ResponsibilityRole"/>
