        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="An abstraction relating a Risk to an organizational resource that is responsible for executing the risk mitigation."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL">
          <details key="OwnsRisk.client" value="Value for the client metaproperty must be stereotyped «OrganizationalResource» or its specializations."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL">
          <details key="OwnsRisk.supplier" value="Value for the supplier metaproperty must be stereotyped «Risk» or its specializations."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="constraints" value="OwnsRiskclient OwnsRisksupplier"/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="baseMetaclass" value="Abstraction"/>
        </eAnnotations>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="OwnsRiskInContext" eSuperTypes="#//Parameters/MeasurableElement sysml.ecore#//Allocations/Allocate">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="An abstraction relating a Risk to an organizational role that is responsible for executing the risk mitigation in the specific context or configuration."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL">
          <details key="OwnsRiskInContext.client" value="Value for the client metaproperty must be stereotyped «ResourceRole» or its specializations."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL">
          <details key="OwnsRiskInContext.supplier" value="Value for the supplier metaproperty must be stereotyped «Risk» or its specializations."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="constraints" value="OwnsRiskInContextclient OwnsRiskInContextsupplier"/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="baseMetaclass" value="Abstraction"/>
        </eAnnotations>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="AffectsInContext" eSuperTypes="#//Parameters/MeasurableElement">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="A dependency that asserts that a Risk is applicable to an AssetRole in the specific context or configuration."/>
