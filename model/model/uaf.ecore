      <eClassifiers xsi:type="ecore:EClass" name="AchievedEffect" eSuperTypes="#//Parameters/MeasurableElement">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="A dependency relationship that exists between an ActualState  (e.g., observed/measured during testing) of an element that attempts to achieve a DesiredEffect and an Achiever."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL">
          <details key="AchievedEffect.client" value="Value for the client metaproperty must be stereotyped by the specialization of «Achiever»."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL">
          <details key="AchievedEffect.supplier" value="Value for the supplier metaproperty must be stereotyped by the specialization of «ActualState»."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="constraints" value="AchievedEffectclient AchievedEffectsupplier"/>
