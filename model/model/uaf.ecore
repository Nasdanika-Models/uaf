    <eSubpackages xsi:type="ecore:EPackage" name="Traceability" nsURI="https://www.omg.org/spec/UAF/20190615/UAF/Security/Traceability" nsPrefix="traceability">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Contains the elements that contribute to the Security Traceability Viewpoint."/>
      </eAnnotations>
      <eClassifiers xsi:type="ecore:EClass" name="Affects" eSuperTypes="#//Parameters/MeasurableElement">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="A dependency that asserts that a Risk is applicable to an Asset."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL">
          <details key="Affects.client" value="Value for the client metaproperty must be stereotyped «Risk» or its specializations."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL">
          <details key="Affects.supplier" value="Value for the supplier metaproperty must be stereotyped «Asset» or its specializations."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="constraints" value="Affectsclient Affectssupplier"/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="baseMetaclass" value="Dependency"/>
        </eAnnotations>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="Mitigates" eSuperTypes="#//Parameters/MeasurableElement">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="A dependency relating a Security Control to a Risk. Mitigation is established to manage risk and could be represented as an overall strategy or through techniques (mitigation configurations) and procedures (SecurityProcesses)."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL">
          <details key="Mitigates.client" value="Value for the client metaproperty must be stereotyped «SecurityControl» or its specializations."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL">
          <details key="Mitigates.supplier" value="Value for the supplier metaproperty must be stereotyped «Risk» or its specializations."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="constraints" value="Mitigatesclient Mitigatessupplier"/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="baseMetaclass" value="Dependency"/>
        </eAnnotations>
      </eClassifiers>
