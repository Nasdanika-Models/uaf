    <eSubpackages xsi:type="ecore:EPackage" name="Taxonomy" nsURI="https://www.omg.org/spec/UAF/20190615/UAF/Strategic/Taxonomy" nsPrefix="taxonomy">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Contains the elements that contribute to the Strategic Taxonomy Viewpoint."/>
      </eAnnotations>
      <eClassifiers xsi:type="ecore:EClass" name="ActualEnterprisePhase" eSuperTypes="#//Parameters/ActualPropertySet #//Metadata/Processes/CapableElement #//Strategic/States/Achiever">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="A phase of an actual enterprise endeavor."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL">
          <details key="ActualEnterprisePhase.classifier" value="Value for the classifier metaproperty must be stereotyped by «EnterprisePhase» or its specializations."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL">
          <details key="ActualEnterprisePhase.start/endDate" value="Must fall within the start and end dates of the enclosing ActualEnterprisePhase having this ActualEnterprisePhase set as a value for a slot."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="constraints" value="ActualEnterprisePhaseclassifier ActualEnterprisePhasestartendDate"/>
