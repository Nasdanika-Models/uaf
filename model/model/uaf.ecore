      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="CapabilityForTask" eSuperTypes="#//Parameters/MeasurableElement sysml.ecore#//Allocations/Allocate">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="An abstraction relationship that asserts that a Capability is required in order for an Enterprise to conduct a phase of an EnduringTask."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL">
          <details key="CapabilityForTask.client" value="Value for the client metaproperty must be stereotyped «Capability» or its specializations."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL">
          <details key="CapabilityForTask.supplier" value="Value for the supplier metaproperty must be stereotyped «ActualEnduringTask» or its specializations."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="constraints" value="CapabilityForTaskclient CapabilityForTasksupplier"/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="baseMetaclass" value="Abstraction"/>
        </eAnnotations>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="EnduringTask" eSuperTypes="#//Parameters/PropertySet sysml.ecore#//Blocks/Block">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="A type of template behavior recognized by an enterprise as being essential to achieving its goals - i.e. a template for a strategic specification of what the enterprise does."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="baseMetaclass" value="Activity"/>
        </eAnnotations>
      </eClassifiers>
