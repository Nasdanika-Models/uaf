      <eClassifiers xsi:type="ecore:EClass" name="WholeLifeEnterprise" eSuperTypes="#//Strategic/Taxonomy/EnterprisePhase">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="A WholeLifeEnterprise is a purposeful endeavor of any size involving people, organizations and supporting systems. It is made up of TemporalParts and StructuralParts."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="baseMetaclass" value="Class"/>
        </eAnnotations>
