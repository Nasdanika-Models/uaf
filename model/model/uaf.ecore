  <eSubpackages xsi:type="ecore:EPackage" name="Strategic" nsURI="https://www.omg.org/spec/UAF/20190615/UAF/Strategic" nsPrefix="strategic">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Stakeholders: Capability Portfolio Managers.  
Concerns: capability management process.  
Definition: describe capability taxonomy, composition, dependencies and evolution."/>
    </eAnnotations>
    <eSubpackages xsi:type="ecore:EPackage" name="Structure" nsURI="https://www.omg.org/spec/UAF/20190615/UAF/Strategic/Structure" nsPrefix="structure">
