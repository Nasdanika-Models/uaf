      </eAnnotations>
      <eClassifiers xsi:type="ecore:EClass" name="Asset" abstract="true" eSuperTypes="#//Operational/Taxonomy/ConceptItem #//Parameters/PropertySet #//Parameters/LocationHolder #//Security/Constraints/SubjectOfSecurityConstraint sysml.ecore#//Blocks/Block">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Asset as applied to Security views, an abstract element that indicates the types of elements that can be considered as a subject for security analysis."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="baseMetaclass" value="Class"/>
        </eAnnotations>
        <eStructuralFeatures xsi:type="ecore:EReference" name="categoryCategorizesAsset" eType="#//Parameters/MeasurementSet"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="OperationalMitigation" eSuperTypes="#//Operational/Structure/OperationalArchitecture">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="A set of OperationalPerformers intended to address against specific operational risks."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="baseMetaclass" value="Class"/>
        </eAnnotations>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="ResourceMitigation" eSuperTypes="#//Resources/Taxonomy/ResourceArchitecture">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="A set of ResourcePerformers intended to address against specific risks."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="baseMetaclass" value="Class"/>
        </eAnnotations>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="SecurityEnclave" eSuperTypes="#//Resources/Taxonomy/ResourceArchitecture">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Collection of information systems connected by one or more internal networks under the control of a single authority and security policy. The systems may be structured by physical proximity or by function, independent of location. "/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="baseMetaclass" value="Class"/>
        </eAnnotations>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="OperationalAsset" abstract="true" eSuperTypes="#//Security/Taxonomy/Asset">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="An abstract element used to group the elements of OperationalAgent and InformationElement allowing them to own InformationRoles."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="baseMetaclass" value="Class"/>
        </eAnnotations>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="ResourceAsset" abstract="true" eSuperTypes="#//Security/Taxonomy/Asset">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="An abstract element used to group the elements of ResourcePerformer and DataElement allowing them to own DataRoles"/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="baseMetaclass" value="Class"/>
        </eAnnotations>
      </eClassifiers>
    </eSubpackages>
