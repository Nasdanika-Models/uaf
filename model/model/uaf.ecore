    <eSubpackages xsi:type="ecore:EPackage" name="Processes" nsURI="https://www.omg.org/spec/UAF/20190615/UAF/Security/Processes" nsPrefix="processes">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Contains the elements that contribute to the Security Processes Viewpoint."/>
      </eAnnotations>
      <eClassifiers xsi:type="ecore:EClass" name="EnhancedSecurityControl" eSuperTypes="#//Security/Constraints/SecurityControl">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Statement of security capability to: (i) build in additional but related, functionality to a basic control; and/or (ii)increase the strength of a basic control."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="baseMetaclass" value="Class"/>
        </eAnnotations>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="SecurityProcessAction" eSuperTypes="#//Operational/Processes/OperationalActivityAction #//Resources/Processes/FunctionAction">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="A call of a SecurityProcess in the context of another SecurityProcess."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL">
          <details key="SecurityControlAction.behavior" value="Value for behavior metaproperty must be stereotyped «SecurityControl» or its specializations."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="constraints" value="SecurityControlActionbehavior"/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="baseMetaclass" value="CallBehaviorAction"/>
        </eAnnotations>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="SecurityProcess" eSuperTypes="#//Operational/Processes/OperationalActivity #//Resources/Processes/Function #//Security/Constraints/SubjectOfSecurityConstraint">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="The security-related procedure that satisfies the security control requirement."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="baseMetaclass" value="Activity"/>
        </eAnnotations>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="Enhances" eSuperTypes="sysml.ecore#//Requirements/DeriveReqt #//Parameters/MeasurableElement">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="A dependency relationship relating the EnhancedSecurityControl to a SecurityControl."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL">
          <details key="Enhances.client" value="Value for the client metaproperty must be stereotyped «EnhancedSecurityControl» or its specializations."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL">
          <details key="Enhances.supplier" value="Value for the supplier metaproperty must be stereotyped «SecurityControl» or its specializations."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="constraints" value="Enhancesclient Enhancessupplier"/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="baseMetaclass" value="Abstraction"/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="baseMetaclass" value="Connector"/>
        </eAnnotations>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="Protects" eSuperTypes="#//Parameters/MeasurableElement">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="A dependency that asserts that a SecurityControl is required to protect an Asset."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL">
          <details key="Protects.client" value="Value for the client metaproperty must be stereotyped «SecurityControl» or its specializations."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL">
          <details key="Protects.supplier" value="Value for the supplier metaproperty must be stereotyped bu the specialization of «Asset»."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="constraints" value="Protectsclient Protectssupplier"/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="baseMetaclass" value="Dependency"/>
        </eAnnotations>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="ProtectsInContext" eSuperTypes="#//Parameters/MeasurableElement">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="A dependency relationship that relates a SecurityControlAction to a OperationalRole, or a ResourceRole. It indicates that SecurityControl is required to protect an Asset in a specific context or configuration."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL">
          <details key="ProtectsInContext.client" value="Value for the client metaproperty must be stereotyped «SecurityControlAction» or its specializations."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL">
          <details key="ProtectsInContext.supplier" value="Value for the supplier metaproperty must be stereotyped «OperationalRole», «ResourceRole», «OperationalConnector», «ResourceConnector», «SecurityProperty» or their specializations."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="constraints" value="ProtectsInContextclient ProtectsInContextsupplier"/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="baseMetaclass" value="Dependency"/>
        </eAnnotations>
      </eClassifiers>
