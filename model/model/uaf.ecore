  <eSubpackages xsi:type="ecore:EPackage" name="Standards" nsURI="https://www.omg.org/spec/UAF/20190615/UAF/Standards" nsPrefix="standards">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Stakeholders: Solution Providers, Systems Engineers, Software Engineers, Systems Architects, Business Architects. 
Concerns: technical and non-technical Standards applicable to the architecture. 
Definition: shows the technical, operational, and business Standards applicable to the architecture. Defines the underlying current and expected Standards."/>
    </eAnnotations>
    <eSubpackages xsi:type="ecore:EPackage" name="Taxonomy" nsURI="https://www.omg.org/spec/UAF/20190615/UAF/Standards/Taxonomy" nsPrefix="taxonomy">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Contains the elements that contribute to the Standards Taxonomy Viewpoint."/>
      </eAnnotations>
      <eClassifiers xsi:type="ecore:EClass" name="Protocol" eSuperTypes="#//Standards/Taxonomy/Standard">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
