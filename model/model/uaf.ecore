        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL">
          <details key="DesiredEffect.client" value="Value for the client metaproperty must be stereotyped a specialization of «Desirer»."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL">
          <details key="DesiredEffect.supplier" value="Value for the supplier metaproperty must be stereotyped a specialization of «ActualState»."/>
