        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Property of a Capability typed by another Capability, enabling whole-part relationships and structures."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL">
          <details key="CapabilityProperty.class" value="Value for class metaproperty must be stereotyped «Capability» or its specializations."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL">
