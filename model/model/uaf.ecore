      <eClassifiers xsi:type="ecore:EClass" name="StructuralPart" eSuperTypes="#//Parameters/MeasurableElement">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Usage of an EnterprisePhase in the context of another EnterprisePhase. It asserts that one EnterprisePhase is a spatial part of another. Creates a whole-part relationship that represents the structure of the EnterprisePhase."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL">
          <details key="StructuralPart.class" value="Value for class metaproperty must be stereotyped «EnterprisePhase» or its specializations."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL">
          <details key="StructuralPart.type" value="Value for type metaproperty must be stereotyped «EnterprisePhase» or its specializations."/>
