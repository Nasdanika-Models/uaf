      <eClassifiers xsi:type="ecore:EClass" name="InformationRole" eSuperTypes="#//Security/Structure/AssetRole">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="A usage of InformationElement that exists in the context of an OperationalAsset. It also allows the representation of the whole-part aggregation of InformationElements."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL">
          <details key="InformationRole.type" value="Value for the type metaproperty must be stereotyped «InformationElement» or its specializations."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL">
          <details key="InformationRole.class" value="Value for the class metaproperty must be stereotyped by the specialization of «OperationalAsset»."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="constraints" value="InformationRoletype InformationRoleclass"/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="baseMetaclass" value="Property"/>
        </eAnnotations>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="AssetRole" abstract="true" eSuperTypes="#//Parameters/MeasurableElement #//Security/Constraints/SubjectOfSecurityConstraint">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="AssetRole as applied to Security views, an abstract element that indicates the type of elements  that can be considered as a subject for security analysis in the particular context."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="baseMetaclass" value="Element"/>
        </eAnnotations>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="DataRole" eSuperTypes="#//Security/Structure/AssetRole">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="A usage of DataElement that exists in the context of an ResourceAsset. It also allows the representation of the whole-part aggregation of DataElements."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL">
          <details key="DataRole.class" value="Value for the class metaproperty must be stereotyped by the specialization of «ResourceAsset»."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL">
          <details key="DataRole.type" value="Value for the type metaproperty must be stereotyped «DataElement» or its specializations."/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="constraints" value="DataRoleclass DataRoletype"/>
        </eAnnotations>
        <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
          <details key="baseMetaclass" value="Element"/>
        </eAnnotations>
      </eClassifiers>
